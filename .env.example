# Konsultasi AI SHRIMY — ditenagai Claude API (Anthropic / adaCODE)
# Salin file ini menjadi .env.local dan isi kunci Anda.
# Jika kunci tidak diisi, SHRIMY tetap berfungsi memakai basis pengetahuan lokal (fallback grounded).

ANTHROPIC_API_KEY=
# Base URL API. Default resmi Anthropic; untuk adaCODE gunakan https://api.adacode.ai
ANTHROPIC_BASE_URL=https://api.anthropic.com
# Model default platform (adaCODE) — dapat diganti ke claude-opus-4-8 dsb.
ANTHROPIC_MODEL=claude-sonnet-4-6
# Nomor WhatsApp layanan pelanggan (untuk eskalasi)
NEXT_PUBLIC_WA_CS=6281234567890

# Autentikasi (PRD §8.2/§8.5 — JWT + refresh token). Rahasia HMAC penandatangan token.
# WAJIB diganti di produksi. Buat acak, mis: openssl rand -hex 32
AUTH_SECRET=
